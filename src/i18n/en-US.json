    },
    "projectCenter": {
      "subtitle": "Cross-platform project command center",
      "description": "Coordinate GitHub, Vercel, Cloudflare, and relay workflows into one execution pipeline."
    },
    "configCenter": {
      "subtitle": "Global configuration, secrets, and policy control",
      "description": "Maintain repo targets, domain settings, and security policies with consistent multi-env governance."
    },
    "insights": {
      "subtitle": "Risk intelligence and remediation overview",
      "description": "Aggregate audit outcomes, trends, and critical findings to prioritize and track fixes."
    },
    "skills": {
      "subtitle": "Reusable skills and workflow templates",
      "description": "Maintain reusable execution playbooks to reduce repetition and improve reliability for complex tasks."
    },
    "memory": {
      "subtitle": "Long-term memory and preferences",
      "description": "Inspect and maintain durable memory entries to keep cross-session context stable and user preferences aligned."
    },
    "logs": {
      "subtitle": "Logs and troubleshooting entry",
      "description": "Inspect key logs from agent, gateway, and web-ui processes to quickly locate runtime failures."
    },
    "github": {
      "subtitle": "Unified GitHub operation console",
      "description": "Operate repositories, issues, and pull requests directly in Web UI and integrate with automation workflows."
    },
    "vercel": {
      "subtitle": "Deployment and domain control",
